{
  "id": "saas",
  "name": "SaaS / B2B",
  "icon": "☁️",
  "version": "1.0.0",
  "description": "멀티테넌시, 구독 결제, 사용량 과금, RBAC, 웹훅 등 SaaS 플랫폼 도메인",
  "defaultStack": {
    "backend": "spring-boot-kotlin",
    "frontend": "nextjs",
    "database": "postgresql",
    "cache": "redis",
    "messageQueue": "rabbitmq",
    "infrastructure": "docker-compose"
  },
  "compliance": ["GDPR", "개인정보보호법", "SOC2", "정보통신망법"],
  "keywords": {
    "tenant": {
      "triggers": ["테넌트", "멀티테넌트", "격리", "tenant", "조직", "워크스페이스"],
      "docs": ["tenant-isolation.md"]
    },
    "subscription": {
      "triggers": ["구독", "플랜", "과금", "빌링", "결제", "업그레이드", "다운그레이드", "가격정책", "무료체험", "트라이얼"],
      "docs": ["subscription-billing.md"]
    },
    "onboarding": {
      "triggers": ["온보딩", "회원가입", "프로비저닝", "초기설정", "가입"],
      "docs": ["onboarding-provisioning.md"]
    },
    "data": {
      "triggers": ["데이터삭제", "GDPR", "탈퇴", "내보내기", "보존", "폐기", "개인정보", "백업"],
      "docs": ["data-lifecycle.md"]
    },
    "usage": {
      "triggers": ["사용량", "쿼터", "리밋", "초과", "미터링", "API키", "피처플래그"],
      "docs": ["usage-metering.md"]
    },
    "webhook": {
      "triggers": ["웹훅", "이벤트알림", "callback", "endpoint", "연동"],
      "docs": ["webhook-integration.md"]
    },
    "auth": {
      "triggers": ["권한", "역할", "RBAC", "퍼미션", "어드민", "초대", "팀", "멤버", "SSO", "SAML"],
      "docs": ["tenant-isolation.md"]
    },
    "sla": {
      "triggers": ["SLA", "업타임", "가용성", "인시던트"],
      "docs": ["tenant-isolation.md"]
    }
  },
  "errorCodePrefix": "SAAS",
  "conventions": {
    "taskPrefix": "SAAS",
    "branchStrategy": "git-flow",
    "commitFormat": "conventional"
  },
  "checklists": [
    "_base:common.md",
    "_base:security-basic.md",
    "_base:architecture.md",
    "tenant-security.md",
    "compliance.md",
    "domain-logic.md"
  ]
}
