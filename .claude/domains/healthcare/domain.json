{
  "id": "healthcare",
  "name": "헬스케어 / 의료",
  "icon": "🏥",
  "version": "1.0.0",
  "description": "PHI 보호, 진료기록, 처방, 환자 동의, 보험 청구 등 헬스케어 서비스 도메인",
  "defaultStack": {
    "backend": "spring-boot-kotlin",
    "frontend": "nextjs",
    "database": "postgresql",
    "cache": "redis",
    "messageQueue": "rabbitmq",
    "infrastructure": "docker-compose"
  },
  "compliance": ["HIPAA", "의료법", "개인정보보호법", "생명윤리법", "진료기록보존규정"],
  "keywords": {
    "patient": {
      "triggers": ["환자", "진료", "내원", "수진", "patient", "환자번호", "MRN"],
      "docs": ["phi-data-handling.md"]
    },
    "phi": {
      "triggers": ["PHI", "보호건강정보", "비식별화", "마스킹", "익명화", "개인건강정보", "의료정보", "민감정보"],
      "docs": ["phi-data-handling.md"]
    },
    "prescription": {
      "triggers": ["처방", "의약품", "조제", "투약", "처방전", "약물상호작용", "DUR"],
      "docs": ["prescription-flow.md"]
    },
    "appointment": {
      "triggers": ["예약", "진료예약", "접수", "외래", "입퇴원", "수납"],
      "docs": ["appointment-flow.md"]
    },
    "consent": {
      "triggers": ["동의", "동의서", "동의철회", "연구동의", "정보제공동의"],
      "docs": ["consent-management.md"]
    },
    "audit": {
      "triggers": ["감사로그", "감사 로그", "접근이력", "열람기록", "접근통제", "audit"],
      "docs": ["audit-trail.md"]
    },
    "ehr": {
      "triggers": ["EMR", "EHR", "전자의무기록", "진료기록", "의무기록", "FHIR", "HL7"],
      "docs": ["access-control.md"]
    },
    "billing": {
      "triggers": ["수가", "보험청구", "비급여", "건강보험", "의료비", "청구", "심사"],
      "docs": ["billing-claims.md"]
    },
    "lab": {
      "triggers": ["검사결과", "혈액검사", "영상", "X-ray", "CT", "MRI", "병리"],
      "docs": ["phi-data-handling.md"]
    },
    "emergency": {
      "triggers": ["응급", "긴급", "Break-the-Glass", "의식불명"],
      "docs": ["access-control.md"]
    }
  },
  "errorCodePrefix": "HC",
  "conventions": {
    "taskPrefix": "HC",
    "branchStrategy": "git-flow",
    "commitFormat": "conventional"
  },
  "checklists": [
    "_base:common.md",
    "_base:security-basic.md",
    "_base:architecture.md",
    "security.md",
    "compliance.md",
    "domain-logic.md"
  ]
}
