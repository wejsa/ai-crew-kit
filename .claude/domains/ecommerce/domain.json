{
  "id": "ecommerce",
  "name": "이커머스",
  "icon": "🛒",
  "version": "1.1.0",
  "description": "상품, 주문, 재고, 배송, 프로모션, 마켓플레이스, 구독 커머스 도메인",
  "defaultStack": {
    "backend": "spring-boot-kotlin",
    "frontend": "nextjs",
    "database": "mysql",
    "cache": "redis",
    "messageQueue": "rabbitmq",
    "infrastructure": "docker-compose"
  },
  "compliance": ["전자상거래법", "소비자보호법", "개인정보보호법", "전자상거래법(통신판매중개의무)"],
  "keywords": {
    "order": {
      "triggers": ["주문", "결제", "구매", "체크아웃", "장바구니"],
      "docs": ["order-flow.md", "payment-integration.md"]
    },
    "inventory": {
      "triggers": ["재고", "품절", "입고", "출고"],
      "docs": ["inventory.md"]
    },
    "shipping": {
      "triggers": ["배송", "택배", "물류", "배송지"],
      "docs": ["shipping.md"]
    },
    "promotion": {
      "triggers": ["쿠폰", "할인", "프로모션", "이벤트"],
      "docs": ["promotion.md"]
    },
    "product": {
      "triggers": ["상품", "카탈로그", "카테고리", "옵션"],
      "docs": ["product.md"]
    },
    "member": {
      "triggers": ["회원", "회원가입", "로그인", "마이페이지", "탈퇴"],
      "docs": ["member.md"]
    },
    "marketplace": {
      "triggers": ["마켓플레이스", "셀러", "판매자", "입점", "수수료", "멀티셀러", "정산"],
      "docs": ["marketplace.md", "seller-settlement.md"]
    },
    "subscription": {
      "triggers": ["구독", "정기배송", "정기결제", "구독커머스", "빌링", "일시정지", "재개", "프로레이션", "일할계산"],
      "docs": ["subscription-commerce.md"]
    }
  },
  "errorCodePrefix": "EC",
  "conventions": {
    "taskPrefix": "EC",
    "branchStrategy": "git-flow",
    "commitFormat": "conventional"
  },
  "checklists": [
    "_base:common.md",
    "_base:security-basic.md",
    "_base:architecture.md",
    "domain-logic.md",
    "compliance.md",
    "performance.md"
  ]
}
