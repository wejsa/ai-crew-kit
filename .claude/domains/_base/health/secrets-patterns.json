{
  "version": "1.0.0",
  "description": "skill-health-check가 자동 로드하는 도메인 무관 시크릿/민감정보 패턴 라이브러리. common.hardcoded는 SEC-05(하드코딩 시크릿), common.runtime은 SEC-01(민감정보 로깅)에서 사용.",
  "common": {
    "hardcoded": [
      {
        "id": "SEC-S01",
        "name": "API 키 하드코딩",
        "pattern": "(?i)\\b(api[_-]?key|apikey)\\s*[:=]\\s*['\"][A-Za-z0-9_\\-]{16,}['\"]",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "API 키 변수에 16자 이상 리터럴 문자열이 직접 할당됨. 환경변수 또는 시크릿 매니저 사용 권장.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**",
          "docs/**",
          "**/*.md",
          "**/migrations/**",
          "**/seed/**"
        ],
        "excludeContexts": ["env_var_reference", "type_declaration", "comment"]
      },
      {
        "id": "SEC-S02",
        "name": "시크릿 / 비공개 키 하드코딩",
        "pattern": "(?i)\\b(secret|private[_-]?key)\\s*[:=]\\s*['\"][A-Za-z0-9_\\-+/=]{16,}['\"]",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "secret 또는 private_key 변수에 16자 이상 리터럴 문자열이 직접 할당됨.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**",
          "docs/**",
          "**/*.md",
          "**/migrations/**",
          "**/seed/**"
        ],
        "excludeContexts": ["env_var_reference", "type_declaration", "comment"]
      },
      {
        "id": "SEC-S03",
        "name": "AWS Access Key ID",
        "pattern": "\\bAKIA[0-9A-Z]{16}\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "AWS Access Key ID 형식(AKIA + 16자) 리터럴 노출. AWS IAM 자격 누출 시 인프라 침해 위험.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**",
          "docs/**",
          "**/*.md"
        ],
        "excludeContexts": ["comment"]
      },
      {
        "id": "SEC-S04",
        "name": "GitHub Personal Access Token",
        "pattern": "\\bghp_[A-Za-z0-9]{36}\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "GitHub PAT 형식(ghp_ + 36자) 리터럴 노출. GitHub 계정/조직 권한 침해 위험.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**",
          "docs/**",
          "**/*.md"
        ],
        "excludeContexts": ["comment"]
      },
      {
        "id": "SEC-S05",
        "name": "Slack Bot/User Token",
        "pattern": "\\bxox[bp]-[A-Za-z0-9]+-[A-Za-z0-9]+(?:-[A-Za-z0-9]+)*\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "Slack Bot 또는 User Token 형식(xoxb- / xoxp-) 리터럴 노출. 워크스페이스 침해 위험.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**",
          "docs/**",
          "**/*.md"
        ],
        "excludeContexts": ["comment"]
      }
    ],
    "runtime": [
      {
        "id": "SEC-S06",
        "name": "비밀번호 로깅",
        "pattern": "(?i)\\b(?:log(?:ger)?|println)\\s*(?:\\.\\w+)?\\s*\\([^)]*\\bpassword\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "logger 호출에 password 변수가 직접 전달됨. 로그 파이프라인 침해 시 평문 노출 위험.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["type_declaration", "comment"]
      },
      {
        "id": "SEC-S07",
        "name": "카드번호 로깅",
        "pattern": "(?i)\\b(?:log(?:ger)?|println)\\s*(?:\\.\\w+)?\\s*\\([^)]*\\b(?:cardNumber|card_number)\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "logger 호출에 cardNumber 변수가 직접 전달됨. PCI-DSS 위반.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["type_declaration", "comment"]
      },
      {
        "id": "SEC-S08",
        "name": "신용카드 정보 로깅",
        "pattern": "(?i)\\b(?:log(?:ger)?|println)\\s*(?:\\.\\w+)?\\s*\\([^)]*\\b(?:creditCard|credit_card)\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "logger 호출에 creditCard 변수가 직접 전달됨. PCI-DSS 위반.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["type_declaration", "comment"]
      },
      {
        "id": "SEC-S09",
        "name": "CVV 로깅",
        "pattern": "(?i)\\b(?:log(?:ger)?|println)\\s*(?:\\.\\w+)?\\s*\\([^)]*\\bcvv\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "logger 호출에 CVV 변수가 직접 전달됨. PCI-DSS 위반 — CVV는 저장/로깅 자체 금지.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["type_declaration", "comment"]
      },
      {
        "id": "SEC-S10",
        "name": "SSN 로깅",
        "pattern": "(?i)\\b(?:log(?:ger)?|println)\\s*(?:\\.\\w+)?\\s*\\([^)]*\\bssn\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "logger 호출에 SSN 변수가 직접 전달됨. HIPAA / 개인정보보호법 위반.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["type_declaration", "comment"]
      },
      {
        "id": "SEC-S11",
        "name": "주민등록 정보 로깅",
        "pattern": "(?:log(?:ger)?|println)\\s*(?:\\.\\w+)?\\s*\\([^)]*주민등록",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "logger 호출에 '주민등록' 키워드 포함. 한국 개인정보보호법 위반.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["comment"]
      },
      {
        "id": "SEC-S12",
        "name": "시크릿 로깅",
        "pattern": "(?i)\\blogger\\s*\\.\\w+\\s*\\([^)]*\\bsecret\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "logger 호출에 secret 변수가 직접 전달됨.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["type_declaration", "comment"]
      },
      {
        "id": "SEC-S13",
        "name": "비밀번호 println 출력",
        "pattern": "(?i)\\bprintln\\s*\\([^)]*\\bpassword\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "println 호출에 password 변수가 직접 전달됨. 디버그 잔재 / 개발 시 흔한 누설 경로.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["comment"]
      },
      {
        "id": "SEC-S14",
        "name": "API 키 로깅",
        "pattern": "(?i)\\b(?:log(?:ger)?|println)\\s*(?:\\.\\w+)?\\s*\\([^)]*\\bapi[_-]?key\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "logger 호출에 API 키 변수가 직접 전달됨.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["type_declaration", "comment"]
      },
      {
        "id": "SEC-S15",
        "name": "토큰 로깅",
        "pattern": "(?i)\\b(?:log(?:ger)?|println)\\s*(?:\\.\\w+)?\\s*\\([^)]*\\btoken\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "logger 호출에 token 변수가 직접 전달됨. 세션/JWT/refresh 토큰 노출 위험.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["type_declaration", "comment"]
      },
      {
        "id": "SEC-S16",
        "name": "Bearer 토큰 로깅",
        "pattern": "(?i)\\b(?:log(?:ger)?|println)\\s*(?:\\.\\w+)?\\s*\\([^)]*\\bbearer\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "logger 호출에 bearer 헤더 또는 변수가 직접 전달됨.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["type_declaration", "comment"]
      },
      {
        "id": "SEC-S17",
        "name": "Authorization 헤더 로깅",
        "pattern": "(?i)\\b(?:log(?:ger)?|println)\\s*(?:\\.\\w+)?\\s*\\([^)]*\\bauthorization\\b",
        "severity": "CRITICAL",
        "confidence": "high",
        "description": "logger 호출에 Authorization 헤더 변수가 직접 전달됨.",
        "excludeFiles": [
          "**/test/**",
          "**/*.test.*",
          "**/*.spec.*",
          "**/__tests__/**"
        ],
        "excludeContexts": ["type_declaration", "comment"]
      }
    ]
  }
}
